# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Ignore bundler config.
/.bundle

# Ignore all environment files (except sample)
.env*
!.env.example

# Ignore all environment files for production/staging
.env.production
.env.staging
.env.local
.env.local.*

# Ignore the default SQLite database.
/db/*.sqlite3
/db/*.sqlite3-*

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore OS-generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Ignore IDE files
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# Ignore coverage directory
/coverage/

# Ignore rspec status file
/.rspec_status

# Ignore node_modules (if using any JS tooling)
/node_modules/

# Ignore public/assets for production
/public/assets
/public/packs
/public/packs-test

# Ignore storage directory (for uploaded files)
/storage/

# Ignore master.key for decrypting credentials.yml.enc
/master.key

# Ignore any credentials files
/config/credentials/*.key
/config/credentials.yml.enc

# Ignore webpacker files (if using)
/bin/webpack
/bin/webpack-dev-server

# Ignore Yarn integrity checksum
/yarn-error.log

# Ignore test reports
/test-reports/

# Ignore Docker backup files
*.bak
*.backup

# Ignore database dumps
/db/backup/
*.sql

# Ignore documentation build files
/doc/

# Ignore Sentry debug files
.sentry-sourcemaps/

# Ignore Bootsnap cache
/tmp/bootsnap-*

# Ignore Vite build artifacts (if using)
/public/vite.json

# Ignore gems installed during development
/vendor/bundle/

# Ignore Spring files
/spring/

# Ignore bootsnap cache
/bootsnap/

# Ignore any lock files that shouldn't be committed
*.lock

# Keep these files (with .keep to track in git)
!/storage/.keep
!/log/.keep
!/tmp/.keep
!/public/.keep
